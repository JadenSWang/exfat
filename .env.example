# ---------------------------------------------------------------------------
# Copy to `.env` (gitignored) and fill in. Values prefixed with EXPO_PUBLIC_
# are embedded in the mobile bundle and are NOT secret (anon key is safe to
# ship; it is gated by Supabase Row Level Security).
# ---------------------------------------------------------------------------

# Supabase project (Project Settings -> API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server / CLI only — NEVER expose these in the app bundle.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-db-password

# Sign in with Apple (used when configuring the Supabase Apple provider).
# Bundle ID is the default Service ID for native iOS Apple sign-in.
APPLE_BUNDLE_ID=com.workout.app

# AI nutrition estimator. In dev this points at the local paseo estimator on the
# host machine (services/estimator), reachable over Tailscale. The app already
# defaults to http://100.64.0.62:8787/estimate — set this only to override.
EXPO_PUBLIC_ESTIMATE_URL=http://100.64.0.62:8787/estimate
# EXPO_PUBLIC_ESTIMATE_TOKEN=   # only if the estimator sets EXFAT_TOKEN

# Optional cloud path only: the Supabase estimate-nutrition edge function uses
# the Anthropic API directly instead of paseo. Not needed for the local setup.
# ANTHROPIC_API_KEY=sk-ant-...  (set as a Supabase secret, never in the app)
